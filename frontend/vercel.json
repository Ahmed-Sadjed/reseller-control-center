{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://reseller-control-center.onrender.com/api/$1" },
    { "source": "/django-admin/(.*)", "destination": "https://reseller-control-center.onrender.com/django-admin/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
